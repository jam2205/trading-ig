# ──────────────────────────────────────────────────────────────────────────────
# IG Markets — trading-ig configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# .env is gitignored and will never be committed.
#
# IG Demo account setup:
#   1. Register at https://www.ig.com/uk/trading-platforms/demo-account
#   2. Log in → My IG → API (top-right menu) → Create API key
#   3. Use your IG username (email) and password below
#
# The IG_SERVICE_* prefix is required by trading_ig/config.py (ConfigEnvVar).
# ACC_TYPE must be "DEMO" or "LIVE".
# ACC_NUMBER is the account ID shown in the IG platform (e.g. "Z12345").
# ──────────────────────────────────────────────────────────────────────────────

IG_SERVICE_USERNAME=your_ig_username_or_email
IG_SERVICE_PASSWORD=your_ig_password
IG_SERVICE_API_KEY=your_ig_api_key
IG_SERVICE_ACC_TYPE=DEMO
IG_SERVICE_ACC_NUMBER=your_account_number

# ──────────────────────────────────────────────────────────────────────────────
# NewsAPI.org — FX news feed
# ──────────────────────────────────────────────────────────────────────────────
# Free key (100 req/day): https://newsapi.org/register
# Used by sample/forex_xl_live.py to populate the News sheet in Excel.
# ──────────────────────────────────────────────────────────────────────────────

NEWSAPI_KEY=your_newsapi_key
